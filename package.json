{
  "name": "turtle-neck-detector",
  "version": "0.1.1",
  "description": "Electron + React + TypeScript desktop app built with Vite.",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run alert-images && npm run build:electron && concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:electron": "tsc -p electron/tsconfig.json --watch --preserveWatchOutput",
    "dev:app": "wait-on tcp:127.0.0.1:5173 dist-electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "start": "electron .",
    "postinstall": "node scripts/copy-mediapipe-assets.mjs",
    "alert-images": "node scripts/generate-alert-image-manifest.mjs",
    "build:electron": "tsc -p electron/tsconfig.json && node scripts/copy-electron-assets.mjs",
    "build": "npm run alert-images && tsc && npm run build:electron && vite build",
    "dist": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --win --x64 --publish never",
    "dist:mac": "npm run build && (CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --publish never || CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac zip --publish never)",
    "dist:win": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64 --publish never",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0"
  },
  "build": {
    "appId": "com.turtleneck.detector",
    "productName": "Turtle Neck Detector",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/app/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.healthcare-fitness",
      "hardenedRuntime": false,
      "identity": null,
      "artifactName": "TurtleNeckDetector-Mac-${version}.${ext}"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "TurtleNeckDetector-Win-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "TurtleNeckDetector-Win-${version}.${ext}"
    }
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.22",
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.11.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
